generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String             @id @default(uuid())
  email             String             @unique
  wixSiteId         String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  hubspotConnection HubspotConnection?
  fieldMappings     FieldMapping[]
  syncLogs          SyncLog[]

  @@index([wixSiteId])
}

model HubspotConnection {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken     String // AES-256 encrypted
  refreshToken    String // AES-256 encrypted
  expiresAt       DateTime
  hubspotPortalId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ContactMapping {
  id               String    @id @default(uuid())
  userId           String
  wixContactId     String
  hubspotContactId String
  lastSyncedAt     DateTime?
  lastSyncSource   String? // 'wix' | 'hubspot'
  lastSyncId       String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@unique([userId, wixContactId])
  @@unique([userId, hubspotContactId])
  @@index([userId])
}

model FieldMapping {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  wixField     String
  hubspotField String
  direction    String // 'wix_to_hubspot' | 'hubspot_to_wix' | 'bidirectional'
  transform    String? // 'lowercase' | 'trim' | null
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, hubspotField])
  @@index([userId])
}

model SyncLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  syncId    String   @unique @default(uuid())
  source    String // 'wix' | 'hubspot' | 'form'
  direction String? // 'wix_to_hubspot' | 'hubspot_to_wix'
  status    String // 'success' | 'failed' | 'skipped'
  entityId  String?
  errorMsg  String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([syncId])
}
